# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider Selection (gemini, openai, anthropic, ollama)
AI_PROVIDER=gemini

# Gemini Settings (default - free tier)
# Available models: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# OpenAI Settings (if using openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Settings (if using anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama Settings (if using local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Database
DATABASE_URL=sqlite:///apartment_bot.db

# Scraping Settings
SCRAPE_INTERVAL_MINUTES=7
MIN_DELAY_SECONDS=1.0
MAX_DELAY_SECONDS=5.0

# Facebook Group URLs (comma-separated)
FACEBOOK_GROUP_URLS=

# Facebook Login (required for group scraping)
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# Optional: Residential Proxy (recommended for avoiding blocks)
# Format: http://user:pass@host:port
# FACEBOOK_PROXY=

# Debug Mode
DEBUG=false
