# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider Selection (gemini, openai, anthropic, ollama)
AI_PROVIDER=gemini

# Optional: Separate AI Provider/Model for Chat operations (Telegram interactive, welcome, sass, rule parsing)
# CHAT_AI_PROVIDER=gemini
# CHAT_MODEL=gemini-3-flash-preview

# Optional: Separate AI Provider/Model for Listing Enrichment (crawling structured data extraction)
# ENRICH_AI_PROVIDER=openai
# ENRICH_MODEL=gpt-4o-mini

# Gemini Settings (default - free tier)
# Available models: gemini-3-flash-preview, gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_503_RETRIES=10

# OpenAI Settings (if using openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Settings (if using anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Ollama Settings (if using local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq Settings (if using groq - fast inference, free tier)
# Get your free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Database
DATABASE_URL=sqlite:///apartment_bot.db

# Scraping Settings
SCRAPE_INTERVAL_MINUTES=7
MIN_DELAY_SECONDS=1.0
MAX_DELAY_SECONDS=5.0

# Facebook Group URLs (comma-separated)
FACEBOOK_GROUP_URLS=

# Facebook Login (required for group scraping)
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# Optional: Residential Proxy (recommended for avoiding blocks)
# Format: http://user:pass@host:port
# FACEBOOK_PROXY=

# Debug Mode
DEBUG=false

# Maintenance
RESET_DB_ON_STARTUP=false
RESET_USERS_ON_STARTUP=false
RESET_PERSONA_CACHE_ON_STARTUP=false
